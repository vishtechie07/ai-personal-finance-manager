# SpendSense — copy to .env for local Docker Compose (never commit .env)
# Trial login after seed: spendsense / TrySpend2026! — see docs/DEMO_CREDENTIALS.md

# --- Local Spring dev (H2) ---
# SPRING_PROFILES_ACTIVE=local

# --- Docker Compose / Render (PostgreSQL) ---
SPRING_PROFILES_ACTIVE=render

# Postgres (Compose: host is "db"; Render: use dashboard values from linked DB)
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=finance
DATABASE_USERNAME=pfm
DATABASE_PASSWORD=changeme

# Or a single JDBC URL (Railway-style; overrides host/port/name when set)
# DATABASE_URL=jdbc:postgresql://HOST:5432/DATABASE

# Required in production (min 32 characters)
JWT_SECRET=change-me-to-a-secret-at-least-32-characters-long

# Optional: separate key for encrypting user OpenAI API keys (defaults to JWT_SECRET)
# SETTINGS_ENCRYPTION_KEY=

# Optional
# JWT_EXPIRATION_MS=86400000
# OPENAI_MODEL=gpt-4o-mini
# Platform OpenAI key for trials (Render: set as secret). Used when users have not saved their own key.
# OPENAI_API_KEY=sk-...
# Render: https://*.onrender.com
# Docker Compose local: http://localhost:*,http://127.0.0.1:*
# CORS_ALLOWED_ORIGIN_PATTERNS=https://*.onrender.com
# APP_SEED_CONSOLIDATE_LEGACY_USERS=false
# APP_SEED_DEMO_ENABLED=false
# APP_REGISTRATION_ENABLED=true
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# APP_RATE_LIMIT_PER_WINDOW=30

# Docker only
# POSTGRES_PASSWORD=changeme
# JAVA_OPTS=-Xmx384m
# STARTUP_MAX_WAIT_SECONDS=120
